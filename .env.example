PORT=4000
MONGODB_URI=mongodb://localhost:27017/ai-study-hub
JWT_SECRET=change-this-secret
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
MOBILE_APP_SCHEME=aistudyhub
TRASH_RETENTION_DAYS=30
JOB_SECRET=replace-with-a-long-random-secret

# Render Free blocks SMTP ports 25, 465, and 587. SendGrid supports STARTTLS on 2525.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=2525
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=AI Study Hub <your-verified-sender@example.com>
EMAIL_SEND_TIMEOUT_MS=10000
EMAIL_REQUIRED=false

# Optional. Defaults to JWT_SECRET and encrypts resendable invitation tokens at rest.
INVITATION_TOKEN_SECRET=replace-with-a-long-random-secret
