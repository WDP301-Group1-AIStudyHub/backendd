{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true
  },
  "include": [
    "src/app.ts",
    "src/server.ts",
    "src/config/**/*",
    "src/controllers/**/*",
    "src/middlewares/**/*",
    "src/models/**/*",
    "src/routes/**/*",
    "src/services/**/*",
    "src/types/**/*",
    "src/utils/**/*",
    "src/validations/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
